---
import Base from '../layouts/Base.astro';
---

<Base title="Editais Analisados">
  <section class="page-header">
    <h1>Editais Analisados</h1>
    <p id="editaisCount">Carregando...</p>
  </section>

  <div class="filters">
    <select id="filterStatus">
      <option value="">Todos os status</option>
      <option value="completo">Completo</option>
      <option value="parcial">Parcial</option>
      <option value="pendente">Pendente</option>
    </select>
    <select id="filterRegime">
      <option value="">Todos os regimes</option>
      <option value="Estatut">Estatutario</option>
      <option value="CLT">CLT</option>
    </select>
  </div>

  <div id="loadingState" class="loading-state">
    <p>Carregando editais...</p>
  </div>

  <div id="emptyState" class="empty-state" style="display:none;">
    <h3>Nenhum edital processado ainda</h3>
    <p>Adicione seu primeiro edital para comecar a analise.</p>
    <a href={`${import.meta.env.BASE_URL}adicionar/`} class="btn btn-primary">+ Adicionar Edital</a>
  </div>

  <div id="tableContainer" class="editais-table-container" style="display:none;">
    <table class="editais-table">
      <thead>
        <tr>
          <th>Orgao</th>
          <th>Cargo</th>
          <th>Banca</th>
          <th>Ano</th>
          <th>Remun. Total Inicial</th>
          <th>Regime</th>
          <th>Status</th>
          <th>Acao</th>
        </tr>
      </thead>
      <tbody id="editaisBody"></tbody>
    </table>
  </div>
</Base>

<script>
  import { listEditais, deleteEdital, formatMoney, getToken, invalidateCache } from '../lib/github-api.js';

  const BASE = document.querySelector('meta[name="base"]')?.content || '/analisador_edital/';
  let allEditais = [];

  async function init() {
    const loading = document.getElementById('loadingState');
    const empty = document.getElementById('emptyState');
    const table = document.getElementById('tableContainer');

    try {
      allEditais = await listEditais();
      allEditais.sort((a, b) => (b.edital_ano || 0) - (a.edital_ano || 0));

      loading.style.display = 'none';

      if (allEditais.length === 0) {
        empty.style.display = 'block';
      } else {
        table.style.display = 'block';
        document.getElementById('editaisCount').textContent = `${allEditais.length} edital(is) no sistema`;
        renderTable(allEditais);
      }
    } catch (err) {
      loading.innerHTML = `<p style="color:var(--danger);">Erro ao carregar: ${err.message}</p>`;
      if (!getToken()) {
        loading.innerHTML += `<p><a href="${BASE}adicionar/">Configure o token primeiro</a></p>`;
      }
    }
  }

  function renderTable(editais) {
    const tbody = document.getElementById('editaisBody');
    tbody.innerHTML = editais.map(ed => `
      <tr data-status="${ed.status || ''}" data-regime="${ed.regime || ''}">
        <td><strong>${ed.sigla || (ed.orgao || '').substring(0, 20)}</strong></td>
        <td>${(ed.cargo || '').substring(0, 40)}</td>
        <td>${ed.banca || '?'}</td>
        <td>${ed.edital_ano || '?'}</td>
        <td class="money">${formatMoney(ed.remuneracao?.remuneracao_total_inicial)}</td>
        <td>${ed.regime || '?'}</td>
        <td><span class="badge badge-${ed.status}">${ed.status || '?'}</span></td>
        <td class="actions-cell">
          <a href="${BASE}editais/ver/?id=${ed.id}" class="btn btn-sm">Ver</a>
          <a href="${BASE}editais/editar/?id=${ed.id}" class="btn btn-sm btn-edit">Editar</a>
          <button class="btn btn-sm btn-delete" data-id="${ed.id}" data-arquivo="${ed.edital_arquivo || ''}">Excluir</button>
        </td>
      </tr>
    `).join('');

    // Bind delete buttons
    tbody.querySelectorAll('.btn-delete').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!getToken()) { alert('Configure o token primeiro.'); return; }
        if (!confirm(`Excluir edital "${btn.dataset.id}"?`)) return;

        btn.disabled = true;
        btn.textContent = '...';
        try {
          await deleteEdital(btn.dataset.id, btn.dataset.arquivo);
          btn.closest('tr').remove();
          allEditais = allEditais.filter(e => e.id !== btn.dataset.id);
          document.getElementById('editaisCount').textContent = `${allEditais.length} edital(is) no sistema`;
        } catch (err) {
          alert(`Erro: ${err.message}`);
          btn.disabled = false;
          btn.textContent = 'Excluir';
        }
      });
    });
  }

  // Filtros
  document.getElementById('filterStatus').addEventListener('change', filtrar);
  document.getElementById('filterRegime').addEventListener('change', filtrar);

  function filtrar() {
    const status = document.getElementById('filterStatus').value;
    const regime = document.getElementById('filterRegime').value;
    document.querySelectorAll('#editaisBody tr').forEach(tr => {
      const matchStatus = !status || tr.dataset.status === status;
      const matchRegime = !regime || (tr.dataset.regime || '').includes(regime);
      tr.style.display = (matchStatus && matchRegime) ? '' : 'none';
    });
  }

  init();
</script>

<style is:global>
  .loading-state { text-align: center; padding: 3rem; color: var(--text-muted); }
  .actions-cell { display: flex; flex-direction: row; gap: 0.3rem; align-items: center; flex-wrap: nowrap; }
  .btn-edit { background: #2563eb; color: white; border: none; padding: 0.3rem 0.6rem; border-radius: 6px; font-size: 0.75rem; font-weight: 600; text-decoration: none; }
  .btn-edit:hover { background: #1d4ed8; }
  .btn-delete { background: #dc2626; color: white; border: none; padding: 0.3rem 0.6rem; border-radius: 6px; cursor: pointer; font-size: 0.75rem; font-weight: 600; }
  .btn-delete:hover { background: #b91c1c; }
  .btn-delete:disabled { opacity: 0.5; cursor: not-allowed; }
</style>
