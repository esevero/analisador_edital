---
import Base from '../layouts/Base.astro';

const editaisFiles = await Astro.glob('../../content/editais/*.md');
const editais = editaisFiles
  .filter(e => !e.file.includes('_schema'))
  .map(e => ({ ...e.frontmatter, url: e.url }))
  .filter(e => e.id)
  .sort((a, b) => (b.edital_ano || 0) - (a.edital_ano || 0));
---

<Base title="Editais Analisados">
  <section class="page-header">
    <h1>📄 Editais Analisados</h1>
    <p>{editais.length} edital(is) no sistema</p>
  </section>

  <div class="filters">
    <select id="filterStatus">
      <option value="">Todos os status</option>
      <option value="completo">Completo</option>
      <option value="parcial">Parcial</option>
      <option value="pendente">Pendente</option>
    </select>
    <select id="filterRegime">
      <option value="">Todos os regimes</option>
      <option value="Estatutário">Estatutário</option>
      <option value="CLT">CLT</option>
    </select>
  </div>

  {editais.length === 0 ? (
    <div class="empty-state">
      <h3>Nenhum edital processado ainda</h3>
      <p>Adicione seu primeiro edital para começar a análise.</p>
      <a href={`${import.meta.env.BASE_URL}adicionar/`} class="btn btn-primary">+ Adicionar Edital</a>
    </div>
  ) : (
    <div class="editais-table-container">
      <table class="editais-table">
        <thead>
          <tr>
            <th>Órgão</th>
            <th>Cargo</th>
            <th>Banca</th>
            <th>Ano</th>
            <th>Remun. Total Inicial</th>
            <th>Regime</th>
            <th>Status</th>
            <th>Ação</th>
          </tr>
        </thead>
        <tbody>
          {editais.map(ed => (
            <tr data-status={ed.status} data-regime={ed.regime}>
              <td><strong>{ed.sigla || ed.orgao?.substring(0, 20)}</strong></td>
              <td>{ed.cargo?.substring(0, 40)}</td>
              <td>{ed.banca || '?'}</td>
              <td>{ed.edital_ano || '?'}</td>
              <td class="money">
                {ed.remuneracao?.remuneracao_total_inicial
                  ? `R$ ${ed.remuneracao.remuneracao_total_inicial.toLocaleString('pt-BR', {minimumFractionDigits: 2})}`
                  : '—'}
              </td>
              <td>{ed.regime || '?'}</td>
              <td><span class={`badge badge-${ed.status}`}>{ed.status}</span></td>
              <td class="actions-cell">
                <a href={`${import.meta.env.BASE_URL}editais/${ed.id}/`} class="btn btn-sm">Ver</a>
                <a href={`${import.meta.env.BASE_URL}editais/editar/?id=${ed.id}`} class="btn btn-sm btn-edit">Editar</a>
                <button class="btn btn-sm btn-delete" data-id={ed.id} data-arquivo={ed.edital_arquivo || ''}>Excluir</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</Base>

<script>
  // Filtros simples client-side
  document.getElementById('filterStatus')?.addEventListener('change', filtrar);
  document.getElementById('filterRegime')?.addEventListener('change', filtrar);
  
  function filtrar() {
    const status = document.getElementById('filterStatus')?.value || '';
    const regime = document.getElementById('filterRegime')?.value || '';
    document.querySelectorAll('tbody tr').forEach(tr => {
      const matchStatus = !status || tr.dataset.status === status;
      const matchRegime = !regime || tr.dataset.regime?.includes(regime);
      tr.style.display = (matchStatus && matchRegime) ? '' : 'none';
    });
  }

  // ─── EXCLUSAO ───
  const REPO_CONFIG = {
    owner: 'esevero',
    repo: 'analisador_edital',
    branch: 'main',
  };

  function getToken() {
    return localStorage.getItem('gh_pat') || '';
  }

  document.querySelectorAll('.btn-delete').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const token = getToken();
      if (!token) {
        alert('Configure o token primeiro na pagina "Adicionar".');
        return;
      }

      const id = btn.dataset.id;
      const arquivo = btn.dataset.arquivo;

      if (!confirm(`Excluir edital "${id}"?\nEssa acao nao pode ser desfeita.`)) return;

      btn.disabled = true;
      btn.textContent = '...';

      try {
        await deleteFile(`content/editais/${id}.md`, token);
        if (arquivo) {
          try { await deleteFile(`editais/${arquivo}`, token); } catch {}
        }
        btn.closest('tr').remove();
        // Atualizar contador
        const count = document.querySelectorAll('tbody tr').length;
        document.querySelector('.page-header p').textContent = `${count} edital(is) no sistema`;
      } catch (err) {
        alert(`Erro ao excluir: ${err.message}`);
        btn.disabled = false;
        btn.textContent = 'Excluir';
      }
    });
  });

  async function deleteFile(path, token) {
    const url = `https://api.github.com/repos/${REPO_CONFIG.owner}/${REPO_CONFIG.repo}/contents/${path}`;
    const getResp = await fetch(url, {
      headers: { 'Authorization': `token ${token}` }
    });
    if (!getResp.ok) throw new Error(`Arquivo nao encontrado: ${path}`);
    const fileData = await getResp.json();

    const delResp = await fetch(url, {
      method: 'DELETE',
      headers: {
        'Authorization': `token ${token}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        message: `Excluir edital: ${path}`,
        sha: fileData.sha,
        branch: REPO_CONFIG.branch,
      }),
    });
    if (!delResp.ok) {
      const err = await delResp.json();
      throw new Error(err.message || `Falha ao deletar ${path}`);
    }
  }
</script>

<style>
  .actions-cell {
    display: flex;
    flex-direction: row;
    gap: 0.3rem;
    align-items: center;
    flex-wrap: nowrap;
  }

  .btn-edit {
    background: #2563eb;
    color: white;
    border: none;
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.75rem;
    font-weight: 600;
    text-decoration: none;
  }
  .btn-edit:hover { background: #1d4ed8; }

  .btn-delete {
    background: #dc2626;
    color: white;
    border: none;
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.75rem;
    font-weight: 600;
    margin-left: 0;
  }
  .btn-delete:hover { background: #b91c1c; }
  .btn-delete:disabled { opacity: 0.5; cursor: not-allowed; }
</style>
