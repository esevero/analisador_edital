---
import Base from '../../layouts/Base.astro';
---

<Base title="Detalhes do Edital">
  <div id="loadingState" class="loading-state">
    <p>Carregando edital...</p>
  </div>

  <div id="editalContent" style="display:none;"></div>
</Base>

<script>
  import { getEdital, deleteEdital, formatMoney, getToken, invalidateCache } from '../../lib/github-api.js';

  const BASE = '/analisador_edital/';
  const params = new URLSearchParams(window.location.search);
  const editalId = params.get('id');

  async function init() {
    const loading = document.getElementById('loadingState');
    const content = document.getElementById('editalContent');

    if (!editalId) {
      loading.innerHTML = '<p style="color:var(--danger);">ID do edital nao informado.</p>';
      return;
    }

    try {
      const ed = await getEdital(editalId);
      loading.style.display = 'none';
      content.style.display = 'block';
      content.innerHTML = renderEdital(ed);
      bindDeleteButton(ed);
    } catch (err) {
      loading.innerHTML = `<p style="color:var(--danger);">Erro: ${err.message}</p>`;
      if (!getToken()) {
        loading.innerHTML += `<p><a href="${BASE}adicionar/">Configure o token primeiro</a></p>`;
      }
    }
  }

  function renderEdital(ed) {
    const venc = ed.remuneracao?.vencimento_base;
    const remTotal = ed.remuneracao?.remuneracao_total_inicial;
    const remMax = ed.remuneracao?.remuneracao_total_maxima;
    const grats = Array.isArray(ed.remuneracao?.gratificacoes) ? ed.remuneracao.gratificacoes : [];

    let html = `
      <section class="page-header">
        <div class="edital-header">
          <span class="badge badge-${ed.status}">${ed.status}</span>
          <span class="badge badge-banca">${ed.banca || '?'}</span>
          ${ed.edital_ano ? `<span class="badge">${ed.edital_ano}</span>` : ''}
        </div>
        <h1>${ed.sigla || ed.orgao || ''}</h1>
        <p class="cargo-subtitle">${ed.cargo || ''}</p>
        ${ed.orgao ? `<p class="orgao-full">${ed.orgao}</p>` : ''}
      </section>

      <section class="financeiro-resumo">
        <div class="finance-cards">
          ${venc ? `<div class="finance-card"><span class="finance-label">Vencimento Base</span><span class="finance-value">${formatMoney(venc)}</span></div>` : ''}
          ${remTotal ? `<div class="finance-card highlight"><span class="finance-label">Remun. Total Inicial</span><span class="finance-value">${formatMoney(remTotal)}</span></div>` : ''}
          ${remMax ? `<div class="finance-card"><span class="finance-label">Remun. Total Maxima</span><span class="finance-value">${formatMoney(remMax)}</span></div>` : ''}
        </div>
      </section>

      <section class="info-grid">
        <div class="info-item"><strong>Regime</strong><span>${ed.regime || 'Nao informado'}</span></div>
        <div class="info-item"><strong>Jornada</strong><span>${ed.jornada_semanal || 'Nao informada'}</span></div>
        <div class="info-item"><strong>Escolaridade</strong><span>${ed.escolaridade || 'Nao informada'}</span></div>
        ${ed.vagas_total ? `<div class="info-item"><strong>Vagas</strong><span>${ed.vagas_total}</span></div>` : ''}
        ${ed.local_trabalho ? `<div class="info-item"><strong>Local</strong><span>${ed.local_trabalho}</span></div>` : ''}
      </section>`;

    // Gratificacoes
    if (grats.length > 0) {
      html += `<section class="section-block"><h2>Gratificacoes</h2><table class="editais-table"><thead><tr><th>Nome</th><th>Valor Inicial</th><th>Valor Maximo</th><th>Percentual</th><th>Obs.</th></tr></thead><tbody>`;
      for (const g of grats) {
        html += `<tr><td><strong>${g.nome || ''}</strong></td><td>${g.valor_inicial ? formatMoney(g.valor_inicial) : '—'}</td><td>${g.valor_maximo ? formatMoney(g.valor_maximo) : '—'}</td><td>${g.percentual || '—'}</td><td>${g.observacao || ''}</td></tr>`;
      }
      html += `</tbody></table></section>`;
    }

    // Beneficios
    if (ed.beneficios) {
      const b = ed.beneficios;
      const items = [];
      if (b.aux_alimentacao) items.push(`<div class="info-item"><strong>Aux. Alimentacao</strong><span>${formatMoney(b.aux_alimentacao)}</span></div>`);
      if (b.aux_saude) items.push(`<div class="info-item"><strong>Aux. Saude</strong><span>${formatMoney(b.aux_saude)}</span></div>`);
      if (b.aux_creche) items.push(`<div class="info-item"><strong>Aux. Creche</strong><span>${formatMoney(b.aux_creche)}</span></div>`);
      if (b.plano_saude) items.push(`<div class="info-item"><strong>Plano de Saude</strong><span>${b.plano_saude}</span></div>`);
      if (b.aux_transporte) items.push(`<div class="info-item"><strong>Transporte</strong><span>${b.aux_transporte}</span></div>`);
      if (items.length > 0) {
        html += `<section class="section-block"><h2>Beneficios</h2><div class="info-grid">${items.join('')}</div></section>`;
      }
    }

    // Titulacao
    if (ed.titulacao && (ed.titulacao.especializacao_percentual || ed.titulacao.mestrado_percentual || ed.titulacao.doutorado_percentual)) {
      html += `<section class="section-block"><h2>Adicional de Titulacao</h2><table class="editais-table"><thead><tr><th>Titulo</th><th>Percentual</th><th>Valor</th></tr></thead><tbody>`;
      if (ed.titulacao.especializacao_percentual) html += `<tr><td>Especializacao</td><td>${ed.titulacao.especializacao_percentual}%</td><td>${ed.titulacao.especializacao_valor ? formatMoney(ed.titulacao.especializacao_valor) : '—'}</td></tr>`;
      if (ed.titulacao.mestrado_percentual) html += `<tr><td>Mestrado</td><td>${ed.titulacao.mestrado_percentual}%</td><td>${ed.titulacao.mestrado_valor ? formatMoney(ed.titulacao.mestrado_valor) : '—'}</td></tr>`;
      if (ed.titulacao.doutorado_percentual) html += `<tr><td>Doutorado</td><td>${ed.titulacao.doutorado_percentual}%</td><td>${ed.titulacao.doutorado_valor ? formatMoney(ed.titulacao.doutorado_valor) : '—'}</td></tr>`;
      html += `</tbody></table>`;
      if (ed.titulacao.observacoes) html += `<p class="obs-text">${ed.titulacao.observacoes}</p>`;
      html += `</section>`;
    }

    // Carreira
    if (ed.carreira && ed.carreira.plano_nome) {
      html += `<section class="section-block"><h2>Carreira</h2><div class="info-grid">`;
      html += `<div class="info-item"><strong>Plano</strong><span>${ed.carreira.plano_nome}</span></div>`;
      if (ed.carreira.niveis) html += `<div class="info-item"><strong>Niveis</strong><span>${ed.carreira.niveis}</span></div>`;
      if (ed.carreira.progressao_horizontal) html += `<div class="info-item"><strong>Prog. Horizontal</strong><span>${ed.carreira.progressao_horizontal}</span></div>`;
      if (ed.carreira.progressao_vertical) html += `<div class="info-item"><strong>Prog. Vertical</strong><span>${ed.carreira.progressao_vertical}</span></div>`;
      if (ed.carreira.tempo_minimo_progressao) html += `<div class="info-item"><strong>Tempo Min.</strong><span>${ed.carreira.tempo_minimo_progressao}</span></div>`;
      html += `</div></section>`;
    }

    // Trabalho
    if (ed.trabalho && ed.trabalho.home_office) {
      html += `<section class="section-block"><h2>Qualidade de Vida</h2><div class="info-grid">`;
      if (ed.trabalho.home_office) html += `<div class="info-item"><strong>Home Office</strong><span>${ed.trabalho.home_office}</span></div>`;
      if (ed.trabalho.dias_remotos) html += `<div class="info-item"><strong>Dias Remotos</strong><span>${ed.trabalho.dias_remotos}</span></div>`;
      if (ed.trabalho.flexibilidade_horario) html += `<div class="info-item"><strong>Flexibilidade</strong><span>${ed.trabalho.flexibilidade_horario}</span></div>`;
      if (ed.trabalho.banco_horas) html += `<div class="info-item"><strong>Banco de Horas</strong><span>${ed.trabalho.banco_horas}</span></div>`;
      html += `</div></section>`;
    }

    // Dados faltantes
    if (Array.isArray(ed.dados_faltantes) && ed.dados_faltantes.length > 0) {
      html += `<section class="section-block alert-block"><h2>Dados Pendentes</h2><p>Os seguintes campos nao foram preenchidos:</p><ul>`;
      for (const d of ed.dados_faltantes) {
        html += `<li>${d.descricao || d.campo} (<code>${d.campo}</code>)</li>`;
      }
      html += `</ul></section>`;
    }

    // Fontes
    if (Array.isArray(ed.fontes) && ed.fontes.length > 0) {
      html += `<section class="section-block"><h2>Fontes</h2><ul>`;
      for (const f of ed.fontes) {
        html += `<li><strong>${f.tipo || ''}:</strong> ${f.descricao || ''}${f.link ? ` <a href="${f.link}" target="_blank">(link)</a>` : ''}${f.data ? ` – ${f.data}` : ''}</li>`;
      }
      html += `</ul></section>`;
    }

    // Actions
    html += `
      <section class="actions-section">
        <a href="${BASE}editais/" class="btn">Voltar para Editais</a>
        <a href="${BASE}editais/editar/?id=${ed.id}" class="btn btn-edit-lg">Editar / Completar Dados</a>
        <button id="btnDelete" class="btn btn-danger">Excluir Edital</button>
      </section>`;

    return html;
  }

  function bindDeleteButton(ed) {
    const btn = document.getElementById('btnDelete');
    if (!btn) return;
    btn.addEventListener('click', async () => {
      if (!getToken()) { alert('Configure o token primeiro.'); return; }
      if (!confirm(`Excluir edital "${ed.sigla || ed.orgao} - ${ed.cargo}"?`)) return;

      btn.disabled = true;
      btn.textContent = 'Excluindo...';
      try {
        await deleteEdital(ed.id, ed.edital_arquivo);
        window.location.href = `${BASE}editais/`;
      } catch (err) {
        alert(`Erro: ${err.message}`);
        btn.disabled = false;
        btn.textContent = 'Excluir Edital';
      }
    });
  }

  init();
</script>

<style is:global>
  .loading-state { text-align: center; padding: 3rem; color: var(--text-muted); }
  .edital-header { display: flex; gap: 0.5rem; margin-bottom: 0.5rem; }
  .cargo-subtitle { font-size: 1.2rem; color: var(--text-muted); margin-top: 0.25rem; }
  .orgao-full { font-size: 0.9rem; color: var(--text-muted); }

  .financeiro-resumo { margin: 2rem 0; }
  .finance-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; }
  .finance-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem; text-align: center; box-shadow: var(--shadow); }
  .finance-card.highlight { background: #f0fdf4; border-color: #86efac; }
  .finance-label { display: block; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.25rem; }
  .finance-value { display: block; font-size: 1.4rem; font-weight: 700; color: var(--text); }

  .info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; margin: 1rem 0; }
  .info-item { display: flex; flex-direction: column; gap: 0.2rem; background: var(--card-bg); padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border); }
  .info-item strong { font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase; }
  .info-item span { font-size: 1rem; }

  .section-block { margin: 2rem 0; }
  .section-block h2 { margin-bottom: 1rem; font-size: 1.3rem; color: var(--primary); }

  .alert-block { background: #fffbeb; border: 1px solid #f59e0b; border-radius: var(--radius); padding: 1.5rem; }
  .obs-text { margin-top: 0.75rem; font-size: 0.9rem; color: var(--text-muted); font-style: italic; }

  .actions-section { margin: 3rem 0; display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; }
  .btn-edit-lg { background: #2563eb; color: white; padding: 0.6rem 1.2rem; border-radius: 8px; font-weight: 600; text-decoration: none; font-size: 0.9rem; }
  .btn-edit-lg:hover { background: #1d4ed8; }
  .btn-danger { background: #dc2626; color: white; border: none; padding: 0.6rem 1.2rem; border-radius: 8px; cursor: pointer; font-size: 0.9rem; font-weight: 600; }
  .btn-danger:hover { background: #b91c1c; }
  .btn-danger:disabled { opacity: 0.6; cursor: not-allowed; }
</style>
